[
  {
    "id": 1,
    "arabic": "أَلَا بِذِكْرِ اللَّهِ تَطْمَئِنُّ الْقُلُوبُ",
    "turkish": "Dikkat edin! Kalpler ancak Allah'ı anmakla huzur bulur.",
