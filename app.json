{
  "expo": {
    "name": "Zikirmatik - Zikir Sayacı",
    "slug": "zikirmatik",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F2EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zikirmatik.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D5A27"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.eraycaylak.zikirmatik",
      "permissions": ["VIBRATE", "RECEIVE_BOOT_COMPLETED", "SCHEDULE_EXACT_ALARM"],
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/b1ffa281-bdda-45ea-a213-9d87c5745e96",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b1ffa281-bdda-45ea-a213-9d87c5745e96"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D5A27"
        }
      ]
    ],
    "platforms": ["ios", "android", "web"]
  }
}
